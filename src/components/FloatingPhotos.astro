---
interface Photo {
  src: string;
  alt: string;
  position: 'left' | 'right';
  top: string;       // e.g. "300px", "50vh"
  rotate?: number;    // degrees
  size?: 'sm' | 'md' | 'lg';
  delay?: number;     // animation delay in ms
}

interface Props {
  photos: Photo[];
}

const { photos } = Astro.props;

const sizeMap = {
  sm: 'w-[140px] h-[100px] md:w-[180px] md:h-[130px]',
  md: 'w-[180px] h-[130px] md:w-[240px] md:h-[170px]',
  lg: 'w-[220px] h-[160px] md:w-[300px] md:h-[210px]',
};
---

<div class="floating-photos-container absolute inset-0 pointer-events-none overflow-hidden" aria-hidden="true">
  {photos.map((photo) => {
    const size = sizeMap[photo.size || 'md'];
    const side = photo.position === 'left' ? 'left: -20px; md:left: 20px;' : 'right: -20px; md:right: 20px;';
    return (
      <div
        class={`floating-photo absolute ${size} opacity-0 transition-all duration-1000 ease-out`}
        data-float-delay={photo.delay || 0}
        style={`
          top: ${photo.top};
          ${photo.position === 'left' ? 'left: 0px;' : 'right: 0px;'}
          transform: rotate(${photo.rotate || 0}deg) translateX(${photo.position === 'left' ? '-60px' : '60px'}) scale(0.9);
        `}
      >
        <div class="relative w-full h-full overflow-hidden border border-mc-border/50 rounded-sm shadow-lg shadow-black/20">
          <img
            src={photo.src}
            alt={photo.alt}
            class="w-full h-full object-cover"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/30 to-transparent"></div>
          <span class="absolute bottom-2 left-3 text-[10px] text-white/70 tracking-wide">{photo.alt}</span>
        </div>
      </div>
    );
  })}
</div>

<style>
  .floating-photo.visible {
    opacity: 0.85 !important;
    transform: rotate(var(--rotate, 0deg)) translateX(0) scale(1) !important;
  }

  .floating-photo:hover {
    opacity: 1 !important;
    z-index: 10;
  }

  /* Hide on small screens where they'd overlap content */
  @media (max-width: 1200px) {
    .floating-photos-container {
      display: none;
    }
  }
</style>

<script is:inline>
(function() {
  function initFloatingPhotos() {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const delay = Number(entry.target.dataset.floatDelay) || 0;
          setTimeout(() => entry.target.classList.add('visible'), delay);
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -100px 0px' });

    document.querySelectorAll('.floating-photo:not(.visible)').forEach(el => {
      observer.observe(el);
    });
  }

  initFloatingPhotos();
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initFloatingPhotos);
  }
  document.addEventListener('astro:page-load', initFloatingPhotos);
})();
</script>
