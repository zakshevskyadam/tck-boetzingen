---
import { t, getLocalizedPath, type Lang } from '../i18n/utils';
import LanguageSwitcher from './LanguageSwitcher.astro';
import ThemeToggle from './ThemeToggle.astro';
import NavMobile from './NavMobile.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const navLinks = [
  { key: 'nav.home', path: '/' },
  { key: 'nav.verein', path: '/verein' },
  { key: 'nav.tennishalle', path: '/tennishalle' },
  { key: 'nav.mitgliedschaft', path: '/mitgliedschaft' },
  { key: 'nav.kontakt', path: '/kontakt' },
];
---

<header
  class="fixed top-0 left-0 right-0 z-100 bg-mc-bg/85 backdrop-blur-[20px] border-b border-mc-border"
>
  <nav class="flex items-center justify-between px-6 md:px-12 py-5" aria-label="Main navigation">
    <!-- Left: Logo -->
    <a href={getLocalizedPath('/', lang)} class="font-heading text-xl text-mc-text flex items-center gap-0 shrink-0">
      TCK<span class="inline-block w-1.5 h-1.5 rounded-full bg-mc-accent mx-0.5 translate-y-[1px]"></span>Bötzingen
    </a>

    <!-- Center: Nav links (desktop) -->
    <div class="hidden md:flex items-center gap-8">
      {navLinks.map((link) => (
        <a
          href={getLocalizedPath(link.path, lang)}
          class="text-mc-text-muted text-[13px] tracking-wide hover:text-mc-accent transition-colors"
        >
          {t(link.key, lang)}
        </a>
      ))}
    </div>

    <!-- Right: Language switcher + ball accent -->
    <div class="hidden md:flex items-center gap-3">
      <ThemeToggle />
      <LanguageSwitcher lang={lang} currentPath={Astro.url.pathname} />
      <div class="w-2.5 h-2.5 rounded-full bg-mc-accent gentlePulse"></div>
    </div>

    <!-- Hamburger (mobile) -->
    <button
      class="md:hidden flex flex-col justify-center items-center w-8 h-8 gap-1.5"
      aria-label="Open menu"
      data-menu-toggle
    >
      <span class="block w-5 h-px bg-white/60"></span>
      <span class="block w-5 h-px bg-white/60"></span>
      <span class="block w-3.5 h-px bg-white/60"></span>
    </button>
  </nav>
</header>

<NavMobile lang={lang} currentPath={Astro.url.pathname} />

<style>
  .gentlePulse {
    animation: gentlePulse 3s ease-in-out infinite;
  }
</style>

<script>
  function initNav() {
    const toggle = document.querySelector('[data-menu-toggle]');
    const menu = document.querySelector('[data-mobile-menu]');
    const close = document.querySelector('[data-menu-close]');

    if (!toggle || !menu || !close) return;

    function openMenu() {
      menu!.classList.remove('opacity-0', 'pointer-events-none');
      menu!.classList.add('opacity-100', 'pointer-events-auto');
    }

    function closeMenu() {
      menu!.classList.add('opacity-0', 'pointer-events-none');
      menu!.classList.remove('opacity-100', 'pointer-events-auto');
    }

    toggle.addEventListener('click', openMenu);
    close.addEventListener('click', closeMenu);

    // Close on link click
    menu.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', closeMenu);
    });
  }

  document.addEventListener('astro:page-load', initNav);
  initNav();
</script>
