---
interface Props {
  title: string;
  date: string;
  description: string;
}

const { title, date, description } = Astro.props;

const formatted = (() => {
  try {
    const d = new Date(date);
    return d.toLocaleDateString('de-DE', { day: '2-digit', month: 'long', year: 'numeric' });
  } catch {
    return date;
  }
})();

const isLong = description.length > 140;
const preview = isLong
  ? description.slice(0, 140).replace(/\s+\S*$/, '') + '…'
  : description;
---

<div class="card-hover relative overflow-hidden bg-white/[0.02] border border-mc-border border-l-2 border-l-mc-accent/60 p-8 transition-all duration-400">
  <time class="text-[11px] tracking-[2px] uppercase text-white/55 block mb-2">{formatted}</time>
  <h3 class="font-heading text-xl font-normal text-mc-text mb-3">{title}</h3>

  {isLong ? (
    <details class="event-details">
      <summary class="cursor-pointer list-none">
        <p class="text-sm leading-relaxed text-white/70 event-preview">{preview}</p>
        <span class="event-toggle text-[11px] tracking-[2px] uppercase text-mc-accent/70 hover:text-mc-accent mt-3 inline-block transition-colors">
          Mehr lesen &rarr;
        </span>
      </summary>
      <p class="text-sm leading-relaxed text-white/70 mt-3 whitespace-pre-wrap">{description}</p>
      <button
        type="button"
        class="event-toggle-close text-[11px] tracking-[2px] uppercase text-mc-accent/70 hover:text-mc-accent mt-3 inline-block transition-colors bg-transparent border-0 p-0 cursor-pointer"
        onclick="this.closest('details').open = false"
      >
        Weniger anzeigen &uarr;
      </button>
    </details>
  ) : (
    <p class="text-sm leading-relaxed text-white/70 whitespace-pre-wrap">{description}</p>
  )}
</div>

<style>
  .event-details summary::-webkit-details-marker { display: none; }
  .event-details[open] .event-preview,
  .event-details[open] .event-toggle { display: none; }
  .event-details:not([open]) .event-toggle-close { display: none; }
</style>
