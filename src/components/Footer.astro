---
import { t, getLocalizedPath, type Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const year = new Date().getFullYear();

const externalLinks = [
  { label: 'Tenniswelt Süd', href: 'https://www.tennis-welt.com' },
  { label: 'Badischer Tennisverband', href: 'http://www.badischertennisverband.de' },
  { label: 'nuLiga', href: 'http://baden.liga.nu' },
  { label: 'Helferliste Online', href: 'https://www.helferliste.online' },
];
---

<footer class="border-t border-mc-border px-6 md:px-12 py-16">
  <div class="flex flex-col md:flex-row justify-between gap-10 md:gap-8">
    <!-- Left: Club name + address -->
    <div class="flex flex-col gap-2">
      <span class="font-heading text-lg text-mc-text">TCK &middot; Bötzingen</span>
      <span class="text-sm text-mc-text-muted">Waldstraße 5, 79268 Bötzingen</span>
    </div>

    <!-- Center: Legal links -->
    <div class="flex items-center gap-4 text-sm text-mc-text-muted">
      <a href={getLocalizedPath('/datenschutz', lang)} class="hover:text-mc-accent/80 transition-colors">
        {t('footer.privacy', lang)}
      </a>
      <span class="text-white/20">|</span>
      <a href={getLocalizedPath('/impressum', lang)} class="hover:text-mc-accent/80 transition-colors">
        {t('footer.imprint', lang)}
      </a>
      <span class="text-white/20">|</span>
      <a href="/keystatic" class="hover:text-mc-accent/80 transition-colors">
        {t('footer.login', lang)}
      </a>
    </div>

    <!-- Right: External links -->
    <div class="flex flex-col gap-2">
      {externalLinks.map((link) => (
        <a
          href={link.href}
          target="_blank"
          rel="noopener"
          class="text-sm text-mc-text-muted hover:text-mc-accent/80 transition-colors"
        >
          {link.label}
        </a>
      ))}
    </div>
  </div>

  <!-- Bottom copyright -->
  <div class="mt-12 text-center text-xs text-mc-text-muted/60">
    &copy; {year} TCK Bötzingen e.V.
  </div>
</footer>
