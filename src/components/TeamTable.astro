---
interface Team {
  name: string;
  league: string;
  trainingDay?: string;
}

interface Props {
  teams: Team[];
  season: string;
}

const { teams, season } = Astro.props;

// Group teams by extracting category from name (e.g. "Herren", "Damen", "Jugend")
const grouped = teams.reduce<Record<string, Team[]>>((acc, team) => {
  // Use first word as category, fallback to "Sonstige"
  const category = team.name.split(/\s+/)[0] || 'Sonstige';
  if (!acc[category]) acc[category] = [];
  acc[category].push(team);
  return acc;
}, {});

const categories = Object.keys(grouped);
---

<div class="space-y-8">
  <p class="text-xs tracking-[2px] text-white/30 uppercase">
    Saison {season}
  </p>

  {categories.map((category) => (
    <div>
      <h3 class="font-heading text-lg text-mc-text mb-3">{category}</h3>
      <div class="overflow-x-auto">
        <table class="w-full text-sm text-left border-collapse">
          <thead>
            <tr class="border-b border-mc-border">
              <th class="py-2 px-4 font-medium text-white/50 text-xs uppercase tracking-wide">Team</th>
              <th class="py-2 px-4 font-medium text-white/50 text-xs uppercase tracking-wide">Liga</th>
              {grouped[category].some(t => t.trainingDay) && (
                <th class="py-2 px-4 font-medium text-white/50 text-xs uppercase tracking-wide">Training</th>
              )}
            </tr>
          </thead>
          <tbody>
            {grouped[category].map((team) => (
              <tr class="border-b border-mc-border transition-colors hover:bg-white/[0.02]">
                <td class="py-2 px-4 text-mc-text">{team.name}</td>
                <td class="py-2 px-4 text-white/40">{team.league}</td>
                {team.trainingDay !== undefined && (
                  <td class="py-2 px-4 text-white/40">{team.trainingDay}</td>
                )}
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  ))}
</div>
