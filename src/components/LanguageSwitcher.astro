---
import { LANGUAGES, getLocalizedPath, type Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
  currentPath: string;
}

const { lang, currentPath } = Astro.props;
---

<nav aria-label="Language switcher" class="flex flex-row items-center gap-2">
  {LANGUAGES.map((l) => {
    const isActive = l.code === lang;
    const href = getLocalizedPath(currentPath, l.code);
    return (
      <a
        href={href}
        class:list={[
          'text-[12px] uppercase tracking-wide transition-colors',
          isActive
            ? 'text-mc-accent font-semibold'
            : 'text-white/30 hover:text-mc-accent/80',
        ]}
        aria-current={isActive ? 'page' : undefined}
      >
        {l.code.toUpperCase()}
      </a>
    );
  })}
</nav>
