---
const inputClass = 'w-full bg-white/5 border border-mc-border text-mc-text px-4 py-3 focus:border-mc-accent/30 focus:outline-none text-sm';
const labelClass = 'block text-xs tracking-[1px] uppercase text-white/40 mb-2';
const checkboxLabelClass = 'flex items-start gap-3 cursor-pointer text-sm text-white/40 hover:text-white/60 transition-colors';
---

<form
  name="contact"
  method="POST"
  data-netlify="true"
  netlify-honeypot="bot-field"
  class="max-w-2xl"
>
  <input type="hidden" name="form-name" value="contact" />
  <p class="hidden"><input name="bot-field" /></p>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 mb-6">
    <div>
      <label for="cf-name" class={labelClass}>Name</label>
      <input type="text" id="cf-name" name="name" required class={inputClass} />
    </div>
    <div>
      <label for="cf-vorname" class={labelClass}>Vorname</label>
      <input type="text" id="cf-vorname" name="vorname" required class={inputClass} />
    </div>
  </div>

  <div class="mb-6">
    <label for="cf-email" class={labelClass}>E-Mail</label>
    <input type="email" id="cf-email" name="email" required class={inputClass} />
  </div>

  <div class="mb-8">
    <label for="cf-nachricht" class={labelClass}>Nachricht</label>
    <textarea id="cf-nachricht" name="nachricht" rows="5" required class={inputClass}></textarea>
  </div>

  <div class="mb-8">
    <label class={checkboxLabelClass}>
      <input type="checkbox" name="datenschutz" required class="mt-0.5 accent-[#c8ff00]" />
      <span>Ich habe die <a href="/datenschutz" class="text-mc-accent/60 hover:text-mc-accent underline-offset-2 hover:underline">Datenschutzerklärung</a> gelesen und stimme der Verarbeitung meiner Daten zu.</span>
    </label>
  </div>

  <button
    type="submit"
    class="cta-sweep inline-block px-9 py-3.5 border border-mc-accent/30 text-mc-accent/80 text-xs tracking-[3px] uppercase transition-colors hover:bg-mc-accent/10 cursor-pointer"
  >
    Absenden
  </button>
</form>
