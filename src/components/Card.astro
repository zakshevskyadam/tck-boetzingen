---
interface Props {
  title: string;
  description: string;
  icon: string;
  href?: string;
}

const { title, description, icon, href } = Astro.props;

const inner = `
  <div class="card-hover group relative overflow-hidden bg-white/[0.02] border border-mc-border p-7 transition-all duration-300 h-full flex flex-col">
    <div class="w-10 h-10 rounded-lg bg-mc-accent/10 flex items-center justify-center mb-5 text-mc-accent/70 transition-colors group-hover:bg-mc-accent/20">
      <span class="text-xl leading-none">${icon}</span>
    </div>
    <h3 class="font-heading text-lg font-normal text-mc-text mb-2">${title}</h3>
    <p class="text-sm leading-relaxed text-white/70 flex-1">${description}</p>
    ${href ? '<div class="mt-4 text-xs text-mc-accent/60 tracking-wide uppercase group-hover:text-mc-accent transition-colors">Mehr erfahren →</div>' : ''}
  </div>
`;
---

{href ? (
  href.startsWith('http') ? (
    <a href={href} target="_blank" rel="noopener noreferrer" class="block no-underline h-full" set:html={inner} />
  ) : (
    <a href={href} class="block no-underline h-full" set:html={inner} />
  )
) : (
  <div set:html={inner} class="h-full" />
)}
