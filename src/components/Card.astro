---
interface Props {
  title: string;
  description: string;
  icon: string;
  href?: string;
}

const { title, description, icon, href } = Astro.props;
---

{href ? (
  <a href={href} class="block no-underline">
    <div class="card-hover relative overflow-hidden bg-white/[0.02] border border-mc-border p-9 transition-all duration-400">
      <span class="text-[28px] block mb-4 opacity-60">{icon}</span>
      <h3 class="font-heading text-[22px] font-normal text-mc-text mb-3">{title}</h3>
      <p class="text-sm leading-relaxed text-white/40">{description}</p>
    </div>
  </a>
) : (
  <div class="card-hover relative overflow-hidden bg-white/[0.02] border border-mc-border p-9 transition-all duration-400">
    <span class="text-[28px] block mb-4 opacity-60">{icon}</span>
    <h3 class="font-heading text-[22px] font-normal text-mc-text mb-3">{title}</h3>
    <p class="text-sm leading-relaxed text-white/40">{description}</p>
  </div>
)}
