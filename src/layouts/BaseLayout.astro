---
import '../styles/global.css';
import '../styles/animations.css';
import SkipToContent from '../components/SkipToContent.astro';
import SEOHead from '../components/SEOHead.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  lang?: string;
  fullScreen?: boolean;
}

const { title, description, lang = 'de', fullScreen = false } = Astro.props;
---

<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <script is:inline>
      (function(){var t=localStorage.getItem('theme');if(t==='light')document.documentElement.setAttribute('data-theme','light');})();
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <SEOHead title={title} description={description} lang={lang} />
    <link rel="icon" type="image/png" href="/images/tck-icon.png" />
    <link rel="apple-touch-icon" href="/images/tck-icon.png" />
    <script src="https://identity.netlify.com/v1/netlify-identity-widget.js" is:inline></script>
    <link rel="preload" href="/fonts/inter-latin-400-normal.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/playfair-display-latin-400-normal.woff2" as="font" type="font/woff2" crossorigin />
  </head>
  <body class="bg-mc-bg text-mc-text-secondary font-body">
    <SkipToContent />
    <Nav lang={lang} />
    <main id="main-content" class={fullScreen ? '' : 'pt-[72px]'}>
      <slot />
    </main>
    <Footer lang={lang} />
  </body>
</html>
