---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroAnimation from '../components/HeroAnimation';
import SectionReveal from '../components/SectionReveal.astro';
import StatsCounter from '../components/StatsCounter';
import Card from '../components/Card.astro';
import EventCard from '../components/EventCard.astro';
import { t, type Lang } from '../i18n/utils';
import { getEvents, getClubInfo } from '../lib/content';

const lang: Lang = 'de';

const now = Date.now();
// Show all events: upcoming first (sorted asc), then past (sorted desc), max 6
const allEvents = getEvents().map(e => ({
  ...e,
  isPast: new Date(e.date).getTime() < now,
}));
const upcoming = allEvents
  .filter(e => !e.isPast)
  .sort((a, b) => new Date(a.date).getTime() - new Date(b.date).getTime());
const past = allEvents
  .filter(e => e.isPast)
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
const events = [...upcoming, ...past].slice(0, 6);

const clubInfo = getClubInfo();
---

<BaseLayout title="TCK Bötzingen – Tennisclub Kaiserstuhl" description="Tennisclub Kaiserstuhl Bötzingen – der älteste Tennisclub am Kaiserstuhl seit 1964." fullScreen={true}>

  <!-- Hero -->
  <HeroAnimation
    client:load
    texts={{
      subtitle: t('hero.subtitle', lang),
      title: t('hero.title', lang),
      tagline: t('hero.tagline', lang),
      cta: t('hero.cta', lang),
      scroll: t('hero.scroll', lang),
    }}
  />

  <!-- Über uns -->
  <section class="relative py-28 px-6 md:px-12 overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/aerial-courts.png" alt="" class="w-full h-full object-cover" loading="lazy" />
    </div>
    <div class="absolute inset-0 bg-mc-bg/85 about-overlay"></div>
    <SectionReveal>
      <div class="max-w-4xl mx-auto relative">
        <div class="text-[11px] tracking-[4px] text-mc-accent uppercase mb-3">{t('about.label', lang)}</div>
        <h2 class="font-heading text-4xl font-light text-mc-text tracking-wide mb-6">{t('about.title', lang)}</h2>
        <p class="text-base leading-relaxed text-white/75 max-w-2xl mb-12">{t('about.text', lang)}</p>
        <StatsCounter
          client:visible
          items={[
            { value: clubInfo.memberCount, label: t('stats.members', lang) },
            { value: clubInfo.courtCount, label: t('stats.courts', lang) },
            { value: clubInfo.hallCount, label: t('stats.indoor', lang) },
            { value: clubInfo.teamCount, label: t('stats.teams', lang) },
          ]}
        />
      </div>
    </SectionReveal>
  </section>

  <!-- Angebot -->
  <section class="py-28 px-6 md:px-12 bg-gradient-to-b from-mc-bg via-mc-bg-alt to-mc-bg">
    <SectionReveal>
      <div class="max-w-5xl mx-auto">
        <div class="text-[11px] tracking-[4px] text-mc-accent/50 uppercase mb-3">{t('offer.label', lang)}</div>
        <h2 class="font-heading text-4xl font-light text-mc-text tracking-wide mb-10">{t('offer.title', lang)}</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 auto-rows-fr">
          <Card
            title={t('offer.hall.title', lang)}
            description={t('offer.hall.desc', lang)}
            icon="🎾"
            href="/verein"
          />
          <Card
            title={t('offer.teams.title', lang)}
            description={t('offer.teams.desc', lang)}
            icon="🏅"
            href="/verein"
          />
          <Card
            title={t('offer.training.title', lang)}
            description={t('offer.training.desc', lang)}
            icon="🎯"
            href="/verein"
          />
          <Card
            title={t('offer.clubhouse.title', lang)}
            description={t('offer.clubhouse.desc', lang)}
            icon="☀️"
          />
          <Card
            title={t('offer.booking.title', lang)}
            description={t('offer.booking.desc', lang)}
            icon="📲"
            href="https://buchung.tck-boetzingen.de"
          />
          <Card
            title={t('offer.fanshop.title', lang)}
            description={t('offer.fanshop.desc', lang)}
            icon="👕"
            href="/fanshop"
          />
        </div>
      </div>
    </SectionReveal>
  </section>

  <!-- Termine -->
  <section class="py-28 px-6 md:px-12 bg-gradient-to-b from-mc-bg via-mc-bg-alt to-mc-bg">
    <SectionReveal>
      <div class="max-w-4xl mx-auto">
        <div class="text-[11px] tracking-[4px] text-mc-accent/50 uppercase mb-3">{t('events.label', lang)}</div>
        <h2 class="font-heading text-4xl font-light text-mc-text tracking-wide mb-10">{t('events.title', lang)}</h2>
        {events.length > 0 ? (
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {events.map((event) => (
              <div class:list={["relative", event.isPast && "opacity-60"]}>
                {event.isPast && (
                  <span class="absolute top-3 right-3 z-10 text-[10px] tracking-[2px] uppercase px-2 py-1 bg-white/10 border border-white/20 text-white/70">
                    Vorbei
                  </span>
                )}
                <EventCard title={event.title} date={event.date} description={event.description} />
              </div>
            ))}
          </div>
        ) : (
          <p class="text-sm text-white/70">Keine Veranstaltungen.</p>
        )}
      </div>
    </SectionReveal>
  </section>

  <!-- CTA -->
  <section class="py-28 px-6 md:px-12">
    <SectionReveal>
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="font-heading text-4xl font-light text-mc-text tracking-wide mb-6">{t('cta.title', lang)}</h2>
        <p class="text-sm leading-relaxed text-white/70 mb-10 max-w-xl mx-auto">{t('cta.text', lang)}</p>
        <a
          href="/kontakt"
          class="cta-sweep inline-block px-9 py-3.5 border border-mc-accent/30 text-mc-accent/80 text-xs tracking-[3px] uppercase transition-colors hover:bg-mc-accent/10"
        >
          {t('cta.button', lang)}
        </a>
      </div>
    </SectionReveal>
  </section>

</BaseLayout>
