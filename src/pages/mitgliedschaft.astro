---
import fs from 'node:fs';
import path from 'node:path';
import yaml from 'js-yaml';
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionReveal from '../components/SectionReveal.astro';
import FaqAccordion from '../components/FaqAccordion.tsx';
import MitgliederserviceForm from '../components/MitgliederserviceForm.astro';
import { t, type Lang } from '../i18n/utils';

const lang: Lang = 'de';

// Fee table data
const fees = [
  { kategorie: 'Erwachsene', grundbeitrag: '205\u00a0\u20ac', ausgleich: '120\u00a0\u20ac (12h \u00d7 10\u00a0\u20ac)', nach30: '135\u00a0\u20ac' },
  { kategorie: 'Ehegatte/Partner', grundbeitrag: '110\u00a0\u20ac', ausgleich: '120\u00a0\u20ac', nach30: '75\u00a0\u20ac' },
  { kategorie: 'Familie', grundbeitrag: '350\u00a0\u20ac', ausgleich: '240\u00a0\u20ac (24h \u00d7 10\u00a0\u20ac)', nach30: '235\u00a0\u20ac' },
  { kategorie: 'Kinder bis 13', grundbeitrag: '55\u00a0\u20ac', ausgleich: '\u2014', nach30: '\u2014' },
  { kategorie: 'Jugendliche 14\u201317', grundbeitrag: '68\u00a0\u20ac', ausgleich: '\u2014', nach30: '\u2014' },
  { kategorie: 'Studenten 18\u201330', grundbeitrag: '115\u00a0\u20ac', ausgleich: '120\u00a0\u20ac', nach30: '75\u00a0\u20ac' },
  { kategorie: 'Passiv', grundbeitrag: '50\u00a0\u20ac', ausgleich: '\u2014', nach30: '\u2014' },
];

// Load FAQ entries
const faqDir = path.resolve('src/content/faq');
const faqSlugs = fs.readdirSync(faqDir).filter((f: string) => {
  const stat = fs.statSync(path.join(faqDir, f));
  return stat.isDirectory();
});

interface FaqEntry {
  question: string;
  answer: string;
  category: string;
  sortOrder: number;
}

const faqEntries: FaqEntry[] = faqSlugs
  .map((slug: string) => {
    const filePath = path.join(faqDir, slug, 'index.yaml');
    if (!fs.existsSync(filePath)) return null;
    const raw = fs.readFileSync(filePath, 'utf-8');
    return yaml.load(raw) as FaqEntry;
  })
  .filter((e): e is FaqEntry => e !== null)
  .sort((a, b) => a.sortOrder - b.sortOrder);

// Group by category
const categoryMap = new Map<string, { q: string; a: string }[]>();
for (const entry of faqEntries) {
  if (!categoryMap.has(entry.category)) {
    categoryMap.set(entry.category, []);
  }
  categoryMap.get(entry.category)!.push({ q: entry.question, a: entry.answer });
}

const categoryLabels: Record<string, string> = {
  mitgliedschaft: 'Mitgliedschaft',
  tennishalle: 'Tennishalle',
  clubhaus: 'Clubhaus',
};

const faqData = Array.from(categoryMap.entries()).map(([key, items]) => ({
  name: categoryLabels[key] || key,
  items,
}));

// Load downloads
const downloadsDir = path.resolve('src/content/downloads');
interface DownloadEntry {
  title: string;
  description: string;
  file?: string;
  sortOrder?: number;
}

let downloads: DownloadEntry[] = [];
if (fs.existsSync(downloadsDir)) {
  const dlSlugs = fs.readdirSync(downloadsDir).filter((f: string) => {
    const p = path.join(downloadsDir, f);
    return fs.statSync(p).isDirectory();
  });
  downloads = dlSlugs
    .map((slug: string) => {
      const filePath = path.join(downloadsDir, slug, 'index.yaml');
      if (!fs.existsSync(filePath)) return null;
      const raw = fs.readFileSync(filePath, 'utf-8');
      return yaml.load(raw) as DownloadEntry;
    })
    .filter((d): d is DownloadEntry => d !== null)
    .sort((a, b) => (a.sortOrder ?? 0) - (b.sortOrder ?? 0));
}
---

<BaseLayout title="Mitgliedschaft – TCK Bötzingen" description="Mitgliedsbeiträge, Arbeitsstunden, FAQ und Downloads des TCK Bötzingen.">

  <!-- Beiträge -->
  <section class="py-28 px-6 md:px-12">
    <SectionReveal>
      <div class="max-w-4xl mx-auto">
        <div class="text-[11px] tracking-[4px] text-mc-accent/50 uppercase mb-3">{t('membership.fees.label', lang)}</div>
        <h2 class="font-heading text-4xl font-light text-mc-text tracking-wide mb-10">{t('membership.fees.title', lang)}</h2>
        <div class="overflow-x-auto">
          <table class="w-full text-sm text-left border-collapse">
            <thead>
              <tr class="border-b border-mc-accent/20">
                <th class="py-3 px-4 font-medium text-mc-accent tracking-wide uppercase text-xs">Kategorie</th>
                <th class="py-3 px-4 font-medium text-mc-accent tracking-wide uppercase text-xs">Grundbeitrag</th>
                <th class="py-3 px-4 font-medium text-mc-accent tracking-wide uppercase text-xs">Ausgleichszahlung</th>
                <th class="py-3 px-4 font-medium text-mc-accent tracking-wide uppercase text-xs">Nach 30.06</th>
              </tr>
            </thead>
            <tbody>
              {fees.map((row) => (
                <tr class="border-b border-mc-border transition-colors hover:bg-white/[0.02]">
                  <td class="py-3 px-4 text-mc-text">{row.kategorie}</td>
                  <td class="py-3 px-4 text-mc-text font-medium">{row.grundbeitrag}</td>
                  <td class="py-3 px-4 text-white/50">{row.ausgleich}</td>
                  <td class="py-3 px-4 text-white/40">{row.nach30}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </SectionReveal>
  </section>

  <!-- Arbeitsstunden -->
  <section class="py-28 px-6 md:px-12 bg-gradient-to-b from-mc-bg via-mc-bg-alt to-mc-bg">
    <SectionReveal>
      <div class="max-w-4xl mx-auto">
        <div class="text-[11px] tracking-[4px] text-mc-accent/50 uppercase mb-3">Arbeitsstunden</div>
        <h2 class="font-heading text-4xl font-light text-mc-text tracking-wide mb-6">Gemeinschaftsarbeit</h2>
        <div class="space-y-4 text-sm leading-relaxed text-white/40 max-w-2xl">
          <p>
            Jedes aktive Mitglied zwischen 18 und 70 Jahren ist verpflichtet, <strong class="text-mc-text font-medium">12 Arbeitsstunden</strong> pro Jahr zu leisten. Familienmitgliedschaften leisten <strong class="text-mc-text font-medium">24 Arbeitsstunden</strong>.
          </p>
          <p>
            Nicht geleistete Stunden werden mit <strong class="text-mc-text font-medium">10&nbsp;&euro; pro Stunde</strong> als Ausgleichszahlung in Rechnung gestellt.
          </p>
          <p>
            Die Arbeitsstunden dienen der Pflege und Instandhaltung unserer Tennisanlage. Typische Aufgaben umfassen Platzpflege, Vereinsfeste und allgemeine Instandhaltungsarbeiten.
          </p>
        </div>
      </div>
    </SectionReveal>
  </section>

  <!-- Aktiv vs Passiv -->
  <section class="py-28 px-6 md:px-12">
    <SectionReveal>
      <div class="max-w-5xl mx-auto">
        <div class="text-[11px] tracking-[4px] text-mc-accent/50 uppercase mb-3">{t('membership.comparison.label', lang)}</div>
        <h2 class="font-heading text-4xl font-light text-mc-text tracking-wide mb-10">{t('membership.comparison.title', lang)}</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <!-- Aktiv -->
          <div class="card-hover relative overflow-hidden bg-mc-accent/[0.04] border border-mc-accent/20 p-8 transition-all duration-400">
            <h3 class="font-heading text-2xl font-light text-mc-accent/80 mb-6">Aktive Mitgliedschaft</h3>
            <ul class="space-y-4">
              <li class="flex items-start gap-3">
                <span class="text-mc-accent/60 mt-0.5">&#10003;</span>
                <span class="text-sm text-white/50">Unbegrenzt auf allen Plätzen spielen</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-mc-accent/60 mt-0.5">&#10003;</span>
                <span class="text-sm text-white/50">12 Arbeitsstunden pro Jahr</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-mc-accent/60 mt-0.5">&#10003;</span>
                <span class="text-sm text-white/50">Vergünstigte Hallenpreise</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-mc-accent/60 mt-0.5">&#10003;</span>
                <span class="text-sm text-white/50">Teilnahme an Mannschaftsspielen</span>
              </li>
            </ul>
          </div>
          <!-- Passiv -->
          <div class="card-hover relative overflow-hidden bg-white/[0.02] border border-mc-border p-8 transition-all duration-400">
            <h3 class="font-heading text-2xl font-light text-mc-text mb-6">Passive Mitgliedschaft</h3>
            <ul class="space-y-4">
              <li class="flex items-start gap-3">
                <span class="text-white/30 mt-0.5">&#8226;</span>
                <span class="text-sm text-white/50">Bis zu 6 Mal pro Jahr spielen</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-white/30 mt-0.5">&#8226;</span>
                <span class="text-sm text-white/50">50&nbsp;&euro; Grundbeitrag</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-white/30 mt-0.5">&#8226;</span>
                <span class="text-sm text-white/50">Keine Arbeitsstunden</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-white/30 mt-0.5">&#8226;</span>
                <span class="text-sm text-white/50">8&nbsp;&euro;/Stunde Gastgebühr auf Außenplätzen</span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </SectionReveal>
  </section>

  <!-- FAQ -->
  <section class="py-28 px-6 md:px-12 bg-gradient-to-b from-mc-bg via-mc-bg-alt to-mc-bg">
    <SectionReveal>
      <div class="max-w-4xl mx-auto">
        <div class="text-[11px] tracking-[4px] text-mc-accent/50 uppercase mb-3">{t('membership.faq.label', lang)}</div>
        <h2 class="font-heading text-4xl font-light text-mc-text tracking-wide mb-10">{t('membership.faq.title', lang)}</h2>
        <FaqAccordion client:visible categories={faqData} />
      </div>
    </SectionReveal>
  </section>

  <!-- Downloads -->
  <section class="py-28 px-6 md:px-12">
    <SectionReveal>
      <div class="max-w-4xl mx-auto">
        <div class="text-[11px] tracking-[4px] text-mc-accent/50 uppercase mb-3">{t('membership.downloads.label', lang)}</div>
        <h2 class="font-heading text-4xl font-light text-mc-text tracking-wide mb-10">{t('membership.downloads.title', lang)}</h2>
        {downloads.length > 0 ? (
          <div class="space-y-4">
            {downloads.map((dl) => (
              <div class="bg-white/[0.02] border border-mc-border p-6 flex items-center justify-between gap-4">
                <div>
                  <h3 class="text-mc-text font-medium text-sm mb-1">{dl.title}</h3>
                  {dl.description && <p class="text-xs text-white/40">{dl.description}</p>}
                </div>
                {dl.file ? (
                  <a
                    href={dl.file}
                    download
                    class="cta-sweep flex-shrink-0 inline-block px-6 py-2.5 border border-mc-accent/30 text-mc-accent/80 text-xs tracking-[2px] uppercase transition-colors hover:bg-mc-accent/10"
                  >
                    Download
                  </a>
                ) : (
                  <span class="text-xs text-white/20 italic flex-shrink-0">Demnächst verfügbar</span>
                )}
              </div>
            ))}
          </div>
        ) : (
          <p class="text-sm text-white/40">Aktuell sind keine Downloads verfügbar. Bitte schauen Sie später wieder vorbei.</p>
        )}
      </div>
    </SectionReveal>
  </section>

  <!-- Mitgliederservice -->
  <section class="py-28 px-6 md:px-12 bg-gradient-to-b from-mc-bg via-mc-bg-alt to-mc-bg">
    <SectionReveal>
      <div class="max-w-4xl mx-auto">
        <div class="text-[11px] tracking-[4px] text-mc-accent/50 uppercase mb-3">{t('membership.service.label', lang)}</div>
        <h2 class="font-heading text-4xl font-light text-mc-text tracking-wide mb-6">{t('membership.service.title', lang)}</h2>
        <p class="text-sm leading-relaxed text-white/40 max-w-2xl mb-10">
          Sie möchten Ihre Daten aktualisieren oder haben ein Anliegen? Nutzen Sie das folgende Formular, um uns schnell und unkompliziert zu kontaktieren.
        </p>
        <MitgliederserviceForm />
      </div>
    </SectionReveal>
  </section>

</BaseLayout>
