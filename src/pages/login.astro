---
export const prerender = false;

import fs from 'node:fs';
import path from 'node:path';
import yaml from 'js-yaml';
import BaseLayout from '../layouts/BaseLayout.astro';
import { verifyPassword, createSession, getSessionFromCookies, SESSION_COOKIE, type Member } from '../lib/auth';

const lang = 'de';

// If already logged in, redirect to dashboard
const existingSession = getSessionFromCookies(Astro.cookies);
if (existingSession) {
  return Astro.redirect('/dashboard');
}

let error = '';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const email = formData.get('email')?.toString().trim().toLowerCase() ?? '';
  const password = formData.get('password')?.toString() ?? '';

  // Load members from YAML files
  const membersDir = path.resolve('src/content/members');
  let member: Member | null = null;

  if (fs.existsSync(membersDir)) {
    const files = fs.readdirSync(membersDir).filter((f: string) => f.endsWith('.yaml') || f.endsWith('.yml'));
    for (const file of files) {
      const data = yaml.load(fs.readFileSync(path.join(membersDir, file), 'utf-8')) as Member;
      if (data.email?.toLowerCase() === email) {
        member = data;
        break;
      }
    }
  }

  if (member && await verifyPassword(password, member.passwordHash)) {
    const sessionId = createSession(member.email);
    Astro.cookies.set(SESSION_COOKIE, sessionId, {
      httpOnly: true,
      secure: import.meta.env.PROD,
      sameSite: 'lax',
      path: '/',
      maxAge: 7 * 24 * 60 * 60,
    });
    // Non-httpOnly flag so the (pre-rendered) nav can detect login state client-side
    Astro.cookies.set('tck_logged_in', '1', {
      httpOnly: false,
      secure: import.meta.env.PROD,
      sameSite: 'lax',
      path: '/',
      maxAge: 7 * 24 * 60 * 60,
    });
    return Astro.redirect('/dashboard');
  } else {
    error = 'Ungültige E-Mail-Adresse oder Passwort.';
  }
}

const inputClass = 'w-full bg-white/5 border border-mc-border text-mc-text px-4 py-3 focus:border-mc-accent/30 focus:outline-none text-sm';
const labelClass = 'block text-xs tracking-[1px] uppercase text-white/70 mb-2';
---

<BaseLayout title="Login – TCK Bötzingen" description="Mitglieder-Login des TCK Bötzingen e.V.">
  <section class="py-28 px-6 md:px-12 min-h-[70vh] flex items-center">
    <div class="max-w-md mx-auto w-full">
      <div class="text-[11px] tracking-[4px] text-mc-accent/50 uppercase mb-3">Mitgliederbereich</div>
      <h1 class="font-heading text-4xl font-light text-mc-text tracking-wide mb-10">Login</h1>

      {error && (
        <div class="mb-6 p-4 border border-red-500/30 bg-red-500/10 text-red-300 text-sm">
          {error}
        </div>
      )}

      <form method="POST" class="space-y-6">
        <div>
          <label for="login-email" class={labelClass}>E-Mail</label>
          <input type="email" id="login-email" name="email" required autocomplete="email" class={inputClass} />
        </div>

        <div>
          <label for="login-password" class={labelClass}>Passwort</label>
          <input type="password" id="login-password" name="password" required autocomplete="current-password" class={inputClass} />
        </div>

        <button
          type="submit"
          class="cta-sweep inline-block px-9 py-3.5 border border-mc-accent/30 text-mc-accent/80 text-xs tracking-[3px] uppercase transition-colors hover:bg-mc-accent/10 cursor-pointer w-full text-center"
        >
          Anmelden
        </button>
      </form>

      <p class="mt-8 text-xs text-white/40 text-center">
        Zugangsdaten erhalten Sie vom Vorstand.
      </p>
    </div>
  </section>
</BaseLayout>
