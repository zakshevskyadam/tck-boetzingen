---
export const prerender = false;

import fs from 'node:fs';
import path from 'node:path';
import yaml from 'js-yaml';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getSessionFromCookies, type Member } from '../lib/auth';

const lang = 'de';

// Check authentication
const session = getSessionFromCookies(Astro.cookies);
if (!session) {
  return Astro.redirect('/login');
}

// Load member data
const membersDir = path.resolve('src/content/members');
let member: Member | null = null;

if (fs.existsSync(membersDir)) {
  const files = fs.readdirSync(membersDir).filter((f: string) => f.endsWith('.yaml') || f.endsWith('.yml'));
  for (const file of files) {
    const data = yaml.load(fs.readFileSync(path.join(membersDir, file), 'utf-8')) as Member;
    if (data.email?.toLowerCase() === session.email.toLowerCase()) {
      member = data;
      break;
    }
  }
}

if (!member) {
  return Astro.redirect('/login');
}

const memberSinceDate = new Date(member.memberSince).toLocaleDateString('de-DE', {
  day: '2-digit',
  month: 'long',
  year: 'numeric',
});

const hoursPercent = Math.min(100, Math.round((member.workHours / member.workHoursRequired) * 100));
const hoursRemaining = Math.max(0, member.workHoursRequired - member.workHours);
---

<BaseLayout title="Mein Bereich – TCK Bötzingen" description="Persönlicher Mitgliederbereich des TCK Bötzingen e.V.">
  <section class="py-28 px-6 md:px-12">
    <div class="max-w-4xl mx-auto">
      <div class="text-[11px] tracking-[4px] text-mc-accent/50 uppercase mb-3">Mitgliederbereich</div>
      <h1 class="font-heading text-4xl font-light text-mc-text tracking-wide mb-2">
        Willkommen, {member.name}
      </h1>
      <p class="text-sm text-white/50 mb-12">{member.email}</p>

      <!-- Cards Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-12">

        <!-- Membership Card -->
        <div class="bg-white/[0.02] border border-mc-border p-6">
          <div class="text-xs tracking-[2px] text-white/55 uppercase mb-4">Mitgliedschaft</div>
          <div class="flex items-baseline gap-3 mb-3">
            <span class="text-2xl font-heading text-mc-text capitalize">{member.membershipType}</span>
            <span class="text-xs text-mc-accent/60 border border-mc-accent/20 px-2 py-0.5 uppercase tracking-wider">
              Mitglied
            </span>
          </div>
          <p class="text-sm text-white/50">Mitglied seit {memberSinceDate}</p>
        </div>

        <!-- Work Hours Card -->
        <div class="bg-white/[0.02] border border-mc-border p-6">
          <div class="text-xs tracking-[2px] text-white/55 uppercase mb-4">Arbeitsstunden</div>
          <div class="flex items-baseline gap-2 mb-3">
            <span class="text-2xl font-heading text-mc-text">{member.workHours}</span>
            <span class="text-sm text-white/40">/ {member.workHoursRequired} Stunden</span>
          </div>
          <!-- Progress Bar -->
          <div class="w-full h-2 bg-white/5 rounded-full overflow-hidden mb-2">
            <div
              class="h-full bg-mc-accent/70 rounded-full transition-all duration-500"
              style={`width: ${hoursPercent}%`}
            ></div>
          </div>
          <p class="text-xs text-white/40">
            {hoursRemaining > 0
              ? `Noch ${hoursRemaining} Stunden offen`
              : 'Alle Stunden geleistet'}
          </p>
        </div>
      </div>

      <!-- Quick Links -->
      <div class="mb-12">
        <div class="text-xs tracking-[2px] text-white/55 uppercase mb-4">Schnellzugriff</div>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          <a
            href="https://buchung.tck-boetzingen.de"
            target="_blank"
            rel="noopener noreferrer"
            class="bg-white/[0.02] border border-mc-border p-5 hover:border-mc-accent/30 transition-colors group"
          >
            <div class="text-sm text-mc-text group-hover:text-mc-accent transition-colors mb-1">Platzbuchung</div>
            <div class="text-xs text-white/40">eBuSy Buchungssystem</div>
          </a>
          <a
            href="/mitgliedschaft#downloads"
            class="bg-white/[0.02] border border-mc-border p-5 hover:border-mc-accent/30 transition-colors group"
          >
            <div class="text-sm text-mc-text group-hover:text-mc-accent transition-colors mb-1">Beitragsordnung</div>
            <div class="text-xs text-white/40">Dokumente & Downloads</div>
          </a>
          <a
            href="/kontakt"
            class="bg-white/[0.02] border border-mc-border p-5 hover:border-mc-accent/30 transition-colors group"
          >
            <div class="text-sm text-mc-text group-hover:text-mc-accent transition-colors mb-1">Kontakt</div>
            <div class="text-xs text-white/40">Vorstand & Ansprechpartner</div>
          </a>
        </div>
      </div>

      <!-- Logout -->
      <a
        href="/logout"
        class="inline-block px-9 py-3.5 border border-white/10 text-white/50 text-xs tracking-[3px] uppercase transition-colors hover:border-white/30 hover:text-white/70"
      >
        Abmelden
      </a>
    </div>
  </section>
</BaseLayout>
