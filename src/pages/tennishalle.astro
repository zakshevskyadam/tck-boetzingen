---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionReveal from '../components/SectionReveal.astro';
import PriceTable from '../components/PriceTable.astro';
import { t, type Lang } from '../i18n/utils';

const lang: Lang = 'de';
---

<BaseLayout title="Tennishalle – TCK Bötzingen" description="Zwei-Feld-Tennishalle des TCK Bötzingen: Preise, Buchung und Informationen zur Hallensaison.">

  <!-- Info -->
  <section class="py-28 px-6 md:px-12">
    <SectionReveal>
      <div class="max-w-4xl mx-auto">
        <div class="text-[11px] tracking-[4px] text-mc-accent/50 uppercase mb-3">{t('hall.info.label', lang)}</div>
        <h2 class="font-heading text-4xl font-light text-mc-text tracking-wide mb-6">{t('hall.info.title', lang)}</h2>
        <div class="space-y-4 text-sm leading-relaxed text-white/40 max-w-2xl mb-10">
          <p>
            Die Tennishalle des TCK Bötzingen verfügt über zwei Hallenplätze mit Teppichbelag und Granulat-Verfüllung. Die Halle bietet optimale Spielbedingungen auch in den kälteren Monaten und ermöglicht ganzjähriges Training und Spielen.
          </p>
          <p>
            Die Hallensaison läuft in der Regel von der ersten Oktoberwoche bis zur letzten Aprilwoche. Die genauen Termine werden jeweils rechtzeitig bekanntgegeben.
          </p>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
          <div class="bg-white/[0.02] border border-mc-border p-6 text-center">
            <div class="font-heading text-3xl font-light text-mc-accent/70 mb-2">2</div>
            <div class="text-xs tracking-[2px] text-white/30 uppercase">Hallenplätze</div>
          </div>
          <div class="bg-white/[0.02] border border-mc-border p-6 text-center">
            <div class="font-heading text-3xl font-light text-mc-accent/70 mb-2">Okt–Apr</div>
            <div class="text-xs tracking-[2px] text-white/30 uppercase">Hallensaison</div>
          </div>
          <div class="bg-white/[0.02] border border-mc-border p-6 text-center">
            <div class="font-heading text-3xl font-light text-mc-accent/70 mb-2">Teppich</div>
            <div class="text-xs tracking-[2px] text-white/30 uppercase">Belag mit Granulat</div>
          </div>
        </div>
      </div>
    </SectionReveal>
  </section>

  <!-- Preise -->
  <section class="py-28 px-6 md:px-12 bg-gradient-to-b from-mc-bg via-mc-bg-alt to-mc-bg">
    <SectionReveal>
      <div class="max-w-4xl mx-auto">
        <div class="text-[11px] tracking-[4px] text-mc-accent/50 uppercase mb-3">{t('hall.prices.label', lang)}</div>
        <h2 class="font-heading text-4xl font-light text-mc-text tracking-wide mb-10">{t('hall.prices.title', lang)}</h2>
        <PriceTable lang={lang} />
      </div>
    </SectionReveal>
  </section>

  <!-- Rabatte -->
  <section class="py-28 px-6 md:px-12">
    <SectionReveal>
      <div class="max-w-4xl mx-auto">
        <div class="text-[11px] tracking-[4px] text-mc-accent/50 uppercase mb-3">{t('hall.discount.label', lang)}</div>
        <h2 class="font-heading text-4xl font-light text-mc-text tracking-wide mb-10">{t('hall.discount.title', lang)}</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="card-hover relative overflow-hidden bg-mc-accent/[0.04] border border-mc-accent/20 p-8 transition-all duration-400">
            <div class="font-heading text-5xl font-light text-mc-accent/60 mb-3">50%</div>
            <h3 class="font-heading text-xl font-normal text-mc-text mb-3">Sommerrabatt</h3>
            <p class="text-sm leading-relaxed text-white/40">
              In den Monaten Mai bis September erhalten alle Spieler 50% Ermäßigung auf die regulären Hallenpreise. Ideal für sommerliches Hallentraining.
            </p>
          </div>
          <div class="card-hover relative overflow-hidden bg-mc-accent/[0.04] border border-mc-accent/20 p-8 transition-all duration-400">
            <div class="font-heading text-5xl font-light text-mc-accent/60 mb-3">50%</div>
            <h3 class="font-heading text-xl font-normal text-mc-text mb-3">Jugendrabatt</h3>
            <p class="text-sm leading-relaxed text-white/40">
              Jugendliche unter 18 Jahren spielen zum halben Preis. Gültig während der gesamten Hallensaison.
            </p>
          </div>
        </div>
      </div>
    </SectionReveal>
  </section>

  <!-- Buchung -->
  <section class="py-28 px-6 md:px-12 bg-gradient-to-b from-mc-bg via-mc-bg-alt to-mc-bg">
    <SectionReveal>
      <div class="max-w-4xl mx-auto">
        <div class="text-[11px] tracking-[4px] text-mc-accent/50 uppercase mb-3">{t('hall.booking.label', lang)}</div>
        <h2 class="font-heading text-4xl font-light text-mc-text tracking-wide mb-6">{t('hall.booking.title', lang)}</h2>
        <div class="space-y-4 text-sm leading-relaxed text-white/40 max-w-2xl mb-10">
          <p>
            Die Buchung der Hallenplätze erfolgt bequem über unser Online-Buchungssystem. Dort können unsere Mitglieder und Gäste verfügbare Zeiten einsehen und direkt buchen.
          </p>
          <p>
            <strong class="text-mc-text font-medium">Zahlungsmöglichkeiten:</strong> Per Lastschrift (Betrag wird von Ihrem Konto abgebucht) oder über ein persönliches Guthabenkonto, das Sie im Buchungssystem unter „Guthaben & Gutscheine" aufladen können.
          </p>
          <p>
            <strong class="text-mc-text font-medium">Dauerschlüssel:</strong> Für Abonnenten und regelmäßige Spieler kann ein personalisierter RFID-Transponder für die elektronische Schließanlage beantragt werden. Pfand: 35 €.
          </p>
          <p>
            <strong class="text-mc-text font-medium">Wichtig:</strong> Bitte tragen Sie in der Halle saubere Tennisschuhe und fegen Sie den Platz nach dem Spiel mit den bereitgestellten Besen.
          </p>
          <p>
            Bei Fragen zur Buchung wenden Sie sich an:
            <a href="mailto:buchung@tck-boetzingen.de" class="text-mc-accent/60 hover:text-mc-accent transition-colors underline-offset-2 hover:underline">
              buchung@tck-boetzingen.de
            </a>
          </p>
        </div>
        <a
          href="https://buchung.tck-boetzingen.de"
          target="_blank"
          rel="noopener noreferrer"
          class="cta-sweep inline-block px-9 py-3.5 border border-mc-accent/30 text-mc-accent/80 text-xs tracking-[3px] uppercase transition-colors hover:bg-mc-accent/10"
        >
          Zur Online-Buchung &rarr;
        </a>
      </div>
    </SectionReveal>
  </section>

  <!-- Leitfaden -->
  <section class="py-28 px-6 md:px-12">
    <SectionReveal>
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="font-heading text-4xl font-light text-mc-text tracking-wide mb-6">Hallenleitfaden</h2>
        <p class="text-sm leading-relaxed text-white/40 max-w-xl mx-auto mb-10">
          Unser Hallenleitfaden enthält alle wichtigen Informationen zur Nutzung der Tennishalle, Hausordnung und Verhaltensregeln.
        </p>
        <a
          href="/downloads/hallenleitfaden.pdf"
          class="cta-sweep inline-block px-9 py-3.5 border border-mc-accent/30 text-mc-accent/80 text-xs tracking-[3px] uppercase transition-colors hover:bg-mc-accent/10"
          download
        >
          Hallenleitfaden herunterladen
        </a>
      </div>
    </SectionReveal>
  </section>

</BaseLayout>
